# =============================================================================
#  AI-Powered Automated Stock Report Generation System — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# =============================================================================

# --- Google Gemini API -------------------------------------------------------
# Get your key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Gemini model to use for AI narrative generation
GEMINI_MODEL=gemini-3.1-flash-lite

# --- Analysis settings -------------------------------------------------------
# Lookback period for price history (yfinance format: 1mo, 3mo, 6mo, 1y, 2y, 5y)
PRICE_HISTORY_PERIOD=1y

# Annualized risk-free rate for Sharpe ratio (decimal, e.g. 0.065 = 6.5%)
RISK_FREE_RATE=0.065

# --- Output settings ---------------------------------------------------------
# Directory where generated reports are saved
OUTPUT_DIR=output

# Default report format: markdown | html | pdf
DEFAULT_FORMAT=markdown
